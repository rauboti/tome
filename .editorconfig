root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Kotlin sources use 4-space indentation
[*.{kt,kts}]
indent_size = 4
# Keep consecutive annotated declarations (e.g. @Autowired fields) as a tight
# block — don't force a blank line before each annotated declaration.
ktlint_standard_spacing-between-declarations-with-annotations = disabled

# Markdown may use trailing whitespace for hard line breaks
[*.md]
trim_trailing_whitespace = false
