                { "value": "strMod", "labelKey": "dnd35.ability.strMod" },
                { "value": "dexMod", "labelKey": "dnd35.ability.dexMod" },
                { "value": "conMod", "labelKey": "dnd35.ability.conMod" },
                { "value": "intMod", "labelKey": "dnd35.ability.intMod" },
                { "value": "wisMod", "labelKey": "dnd35.ability.wisMod" },
                { "value": "chaMod", "labelKey": "dnd35.ability.chaMod" }
              ]
            },
            { "id": "misc", "labelKey": "dnd35.attack.misc", "type": "int" },
            {
              "id": "attackBonus",
              "labelKey": "dnd35.attack.bonus",
              "type": "derived",
              "derivedFrom": "baseAttackBonus + ref(ability) + misc"
            },
            { "id": "damage", "labelKey": "dnd35.attack.damage", "type": "text" },
            { "id": "critical", "labelKey": "dnd35.attack.critical", "type": "text" },
            { "id": "range", "labelKey": "dnd35.attack.range", "type": "text" },
            { "id": "notes", "labelKey": "dnd35.attack.notes", "type": "text" }
          ]
        }
      ]
    },
