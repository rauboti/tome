{
  "ruleSetId": "dnd35",
  "version": "1.0.0",
  "sections": [
    {
      "id": "identity",
      "labelKey": "dnd35.section.identity",
      "columns": 2,
      "fields": [
        { "id": "name", "labelKey": "dnd35.field.name", "type": "text" },
        { "id": "player", "labelKey": "dnd35.field.player", "type": "text" },
        { "id": "race", "labelKey": "dnd35.field.race", "type": "text" },
        { "id": "class", "labelKey": "dnd35.field.class", "type": "text" },
        {
          "id": "alignment",
          "labelKey": "dnd35.field.alignment",
          "type": "select",
          "options": [
            { "value": "LG", "labelKey": "dnd35.alignment.LG" },
            { "value": "NG", "labelKey": "dnd35.alignment.NG" },
            { "value": "CG", "labelKey": "dnd35.alignment.CG" },
            { "value": "LN", "labelKey": "dnd35.alignment.LN" },
            { "value": "TN", "labelKey": "dnd35.alignment.TN" },
            { "value": "CN", "labelKey": "dnd35.alignment.CN" },
            { "value": "LE", "labelKey": "dnd35.alignment.LE" },
            { "value": "NE", "labelKey": "dnd35.alignment.NE" },
            { "value": "CE", "labelKey": "dnd35.alignment.CE" }
          ]
        },
        { "id": "deity", "labelKey": "dnd35.field.deity", "type": "text" },
        {
          "id": "size",
          "labelKey": "dnd35.field.size",
          "type": "select",
          "colSpan": 2,
          "options": [
            { "value": "small", "labelKey": "dnd35.size.small" },
            { "value": "medium", "labelKey": "dnd35.size.medium" },
            { "value": "large", "labelKey": "dnd35.size.large" }
          ]
        },
        { "id": "level", "labelKey": "dnd35.field.level", "type": "int" },
        { "id": "experience", "labelKey": "dnd35.field.experience", "type": "int" }
      ]
    },
    {
      "id": "abilities",
      "labelKey": "dnd35.section.abilities",
      "columns": 4,
      "fields": [
        { "id": "strength", "labelKey": "dnd35.field.strength", "type": "int" },
        { "id": "strMod", "labelKey": "dnd35.field.strMod", "type": "derived", "derivedFrom": "floor((strength - 10) / 2)" },
        { "id": "dexterity", "labelKey": "dnd35.field.dexterity", "type": "int" },
        { "id": "dexMod", "labelKey": "dnd35.field.dexMod", "type": "derived", "derivedFrom": "floor((dexterity - 10) / 2)" },
        { "id": "constitution", "labelKey": "dnd35.field.constitution", "type": "int" },
        { "id": "conMod", "labelKey": "dnd35.field.conMod", "type": "derived", "derivedFrom": "floor((constitution - 10) / 2)" },
        { "id": "intelligence", "labelKey": "dnd35.field.intelligence", "type": "int" },
        { "id": "intMod", "labelKey": "dnd35.field.intMod", "type": "derived", "derivedFrom": "floor((intelligence - 10) / 2)" },
        { "id": "wisdom", "labelKey": "dnd35.field.wisdom", "type": "int" },
        { "id": "wisMod", "labelKey": "dnd35.field.wisMod", "type": "derived", "derivedFrom": "floor((wisdom - 10) / 2)" },
        { "id": "charisma", "labelKey": "dnd35.field.charisma", "type": "int" },
        { "id": "chaMod", "labelKey": "dnd35.field.chaMod", "type": "derived", "derivedFrom": "floor((charisma - 10) / 2)" }
      ]
    },
    {
      "id": "combat",
      "labelKey": "dnd35.section.combat",
      "columns": 4,
      "fields": [
        { "id": "hpMax", "labelKey": "dnd35.field.hpMax", "type": "int" },
        { "id": "hpCurrent", "labelKey": "dnd35.field.hpCurrent", "type": "int" },
        { "id": "baseAttackBonus", "labelKey": "dnd35.field.baseAttackBonus", "type": "int" },
        { "id": "grappleSizeMod", "labelKey": "dnd35.field.grappleSizeMod", "type": "int" },
        { "id": "initiative", "labelKey": "dnd35.field.initiative", "type": "derived", "derivedFrom": "dexMod" },
        { "id": "grapple", "labelKey": "dnd35.field.grapple", "type": "derived", "derivedFrom": "baseAttackBonus + strMod + grappleSizeMod" }
      ]
    },
    {
      "id": "defense",
      "labelKey": "dnd35.section.defense",
      "columns": 3,
      "fields": [
        {
          "id": "armorClass",
          "labelKey": "dnd35.field.armorClass",
          "type": "derived",
          "derivedFrom": "10 + armorBonus + shieldBonus + dexMod + sizeMod + naturalArmor + deflection + dodge"
        },
        {
          "id": "touchAC",
          "labelKey": "dnd35.field.touchAC",
          "type": "derived",
          "derivedFrom": "10 + dexMod + sizeMod + deflection + dodge"
        },
        {
          "id": "flatFootedAC",
          "labelKey": "dnd35.field.flatFootedAC",
          "type": "derived",
          "derivedFrom": "10 + armorBonus + shieldBonus + sizeMod + naturalArmor + deflection"
        },
        { "id": "armorBonus", "labelKey": "dnd35.field.armorBonus", "type": "int" },
        { "id": "shieldBonus", "labelKey": "dnd35.field.shieldBonus", "type": "int" },
        { "id": "naturalArmor", "labelKey": "dnd35.field.naturalArmor", "type": "int" },
        { "id": "deflection", "labelKey": "dnd35.field.deflection", "type": "int" },
        { "id": "dodge", "labelKey": "dnd35.field.dodge", "type": "int" },
        { "id": "sizeMod", "labelKey": "dnd35.field.sizeMod", "type": "int" }
      ]
    },
    {
      "id": "saves",
      "labelKey": "dnd35.section.saves",
      "columns": 2,
      "fields": [
        { "id": "fortBase", "labelKey": "dnd35.field.fortBase", "type": "int" },
        { "id": "fortitude", "labelKey": "dnd35.field.fortitude", "type": "derived", "derivedFrom": "fortBase + conMod" },
        { "id": "refBase", "labelKey": "dnd35.field.refBase", "type": "int" },
        { "id": "reflex", "labelKey": "dnd35.field.reflex", "type": "derived", "derivedFrom": "refBase + dexMod" },
        { "id": "willBase", "labelKey": "dnd35.field.willBase", "type": "int" },
        { "id": "will", "labelKey": "dnd35.field.will", "type": "derived", "derivedFrom": "willBase + wisMod" }
      ]
    },
    {
      "id": "attacks",
      "labelKey": "dnd35.section.attacks",
      "fields": [
        {
          "id": "attacks",
          "labelKey": "dnd35.field.attacks",
