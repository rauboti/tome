# Copy to `.env` for local development (`.env` is gitignored). Defaults are set in
# docker-compose.yml, so an empty .env still boots the stack; override as needed.
#
# Ports (tome uses the 3040/5040/5436 band — reserved for tome in the platform stack,
# clear of hive 3000/5000/5432, taskmaster 3010/5010/5433, pulse 3020/5020/5434,
# avec 3030/5030/5435 and pokedex 3050/5050/5437):
#   Dev:    web `yarn dev` on 5173, proxying /api to the api on 5040 (run the api
#           via `docker compose up tome-db tome-api`). One web dev server at a time.
#   Docker: web 3040, api 5040, db 5436 (the api listens on 8080 inside its container).

# ---- Database (MongoDB container + the api datasource) ----
# Single-node replica set — required for multi-document transactions + @Version
# optimistic concurrency (research §D5). docker-compose.yml assembles the api's
# connection URI from these parts against the tome-db service name.
MONGO_DB=tome
MONGO_USER=tome
MONGO_PASSWORD=tome_local_dev
MONGO_REPLICA_SET=rs0
# Host port for the db (5436 — tome's reserved band; maps to the container's 27017).
MONGO_PORT=5436
# Running the api on the HOST (yarn dev / IDE) instead of in Docker: the in-container
# replica set advertises the service name `tome-db`, which the host can't resolve, so
# connect directly against the mapped port. Uncomment to override the api's URI:
#   SPRING_MONGODB_URI=mongodb://tome:tome_local_dev@localhost:5436/tome?authSource=admin&directConnection=true

# ---- API ----
# Origins allowed to call the api. Comma-separated. The dev web (5173) calls the
# api cross-origin; the Docker web (3040) is same-origin via nginx, so CORS isn't
# exercised there, but it's listed for completeness.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3040

# ---- Hive (identity) — consumer integration (research D1) ----
# The api validates Hive-issued JWTs (JWKS) and runs the OAuth login exchange. Two bases:
# EXTERNAL is how the *browser* reaches Hive (authorize redirect) and the expected token `iss`;
# INTERNAL is how the *api container* reaches Hive (token exchange + JWKS). The endpoint paths
# (/oauth2/authorize, /oauth2/token, /.well-known/jwks.json) are derived in code.
# Standalone they can be equal; in the shared Docker stack INTERNAL is Hive's service name
# (e.g. http://hive-api:8080) while EXTERNAL stays the browser-facing localhost URL.
HIVE_EXTERNAL_URL=http://localhost:5000
HIVE_INTERNAL_URL=http://localhost:5000
HIVE_CLIENT_ID=tome
# Client secret issued by Hive when Tome is registered as an OAuth client (research D1/D6 —
# a maintainer-approved cross-repo change). Leave blank until then; the dev profile default
# (tome-local-dev) matches the dev seed for local login.
HIVE_CLIENT_SECRET=

# The public web origin. The BFF redirects the browser here after login AND derives its OAuth
# redirect URI from it as {WEB_BASE_URL}/auth/callback (register THAT redirect in Hive). The
# browser reaches the callback via the web origin — nginx (Docker) / the Vite proxy (dev) forward
# /auth to the api. For the Docker stack this is the nginx origin (3040).
WEB_BASE_URL=http://localhost:3040

# ---- Frontend (dev) ----
# The api origin the SPA calls in `yarn dev` (the api's published port, 5040). In
# the container, nginx proxies /api instead, so this is only used for local dev.
VITE_API_ORIGIN=http://localhost:5040

# ---- Build ----
# GitHub Packages token (read:packages) for the private @rauboti/ui scope. Needed
# only to build the `web` image (docker compose up --build) — passed as a BuildKit
# secret, never baked into a layer. Same token as web/.yarnrc.yml. Leave blank to
# skip building the web image.
RAUBOTI_PACKAGE_TOKEN=
