# Keep the build context lean and the registry token out of it.
node_modules/
dist/
dist-ssr/
.vite/
coverage/
*.tsbuildinfo
.eslintcache

# The real yarnrc carries the read:packages token — never ship it into the build
# context. The build regenerates it from .yarnrc.yml.example via a BuildKit secret.
.yarnrc.yml

# Dev env overrides must not leak into the production bundle (the template stays).
.env
.env.*
!.env.example

.git/
*.md
